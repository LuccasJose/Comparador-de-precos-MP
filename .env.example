# ============================================
# CONFIGURAÇÃO DO GOOGLE GEMINI
# ============================================

# Chave de API do Google Gemini (OBRIGATÓRIO)
# Obtenha em: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=sua_chave_aqui

# Modelo Gemini a usar (opcional; padrão: gemini-2.5-flash-lite)
# Opções: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash
# Nota: gemini-2.5-flash-lite é mais rápido, barato e econômico em tokens
# GEMINI_MODEL=gemini-2.5-flash-lite

# Timeout para requisições ao Gemini em segundos (opcional; padrão: 30)
# Reduzido para 30s para economizar tokens em requisições lentas
# GEMINI_TIMEOUT_SECONDS=30

# Número máximo de tentativas com retry (opcional; padrão: 2)
# Reduzido para 2 para economizar tokens em falhas
# GEMINI_MAX_RETRIES=2

# ============================================
# OTIMIZAÇÃO DE TOKENS
# ============================================

# Modo de prompt (opcional; padrão: otimizado)
# Opções: otimizado (conciso), detalhado (mais instruções)
# GEMINI_PROMPT_MODE=otimizado

# Máximo de linhas do OCR a processar (opcional; padrão: 100)
# Reduzir para economizar tokens
# OCR_MAX_LINHAS=100

# Modo de processamento do OCR (opcional; padrão: itens_preco)
# - itens_preco: tenta preservar pares item↔preço (inclui contexto quando o preço vem sozinho)
# - completo: envia texto limpo completo (maior custo, usar só se necessário)
# OCR_MODE=itens_preco

# Quantas linhas anteriores usar para associar preço quando ele aparece sozinho (opcional; padrão: 1)
# OCR_PRECO_CONTEXTO=1

# Se a extração de itens ficar muito pequena, faz fallback para texto completo (opcional; padrão: 1)
# (1 = só faz fallback se não extrair nada)
# OCR_MIN_ITENS_FALLBACK=1

# ============================================
# FUZZY MATCHING
# ============================================

# Threshold de similaridade para fuzzy matching (opcional; padrão: 65)
# Valores típicos: 60 (mais permissivo) a 80 (mais rigoroso)
# Usado para comparar nomes de itens entre cardápios
# FUZZY_THRESHOLD=65

